# 网页分享服务 - 环境变量示例
# 复制此文件为 .env 并填充真实值
# .env 已加入 .gitignore，不会被提交

# ========== 必填项 ==========

# JWT 签名密钥，至少 32 位随机字符
JWT_SECRET=your-random-jwt-secret-at-least-32-characters-long

# 公网域名，用于生成分享链接和 OAuth 回调
PUBLIC_DOMAIN=your-domain.com

# 飞书应用 ID
FEISHU_APP_ID=cli_xxxxx

# 飞书应用密钥
FEISHU_APP_SECRET=xxxxxxxxx

# ========== 可选项 ==========

# OAuth 回调地址，默认自动拼接为 https://${PUBLIC_DOMAIN}/oauth2/callback
# REDIRECT_URI=https://your-domain.com/oauth2/callback

# 服务端口，默认 9080
# PORT=9080

# 文件存储基础路径，默认服务内相对路径 ./storage
# STORAGE_BASE_PATH=/path/to/storage
